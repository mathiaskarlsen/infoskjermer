<?php

function signage_display_theme() {
  return [
    'page__screen' => [
      'template' => 'page--screen',
      'base hook' => 'page',
    ],
  ];
}

function signage_display_theme_suggestions_page_alter(&$suggestions, $variables) {
  $path = \Drupal::service('path.current')->getPath();
  if (str_starts_with($path, '/player')) {
    $suggestions[] = 'page__screen';
  }
}
